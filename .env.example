# MODO DEMO: sin ninguna key, la app corre con datos de ejemplo (Tokio).
# Ve añadiendo las keys cuando quieras funciones reales.
#
# Supabase (login, guardar viajes, panel admin). Sin esto = modo demo sin sesión.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
# Proveedor de IA: 'anthropic' (Claude, producción) o 'groq' (gratis, pruebas)
AI_PROVIDER=anthropic
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Si agotas el límite diario de tokens de Groq (TPD), usa un modelo con más
# cuota gratuita, p. ej.: GROQ_MODEL=llama-3.1-8b-instant
# Modelo y tope de tokens para la generación de itinerarios (opcional).
# Con Anthropic se usa este modelo; con Groq manda GROQ_MODEL.
AI_ITINERARY_MODEL=claude-sonnet-4-6
AI_ITINERARY_MAX_TOKENS=4096
# Mapa: usa MapLibre + OpenFreeMap (gratis, sin token). No requiere variable.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
GOOGLE_MAPS_API_KEY=
OPENWEATHER_API_KEY=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
STRIPE_PRICE_PER_TRIP=
STRIPE_PRICE_GROUP=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
