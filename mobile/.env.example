# computer's LAN IP, NOT localhost, e.g. http://192.168.1.50:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Public web app — opened in-app for Stripe checkout (Pro upgrade)
EXPO_PUBLIC_WEB_URL=http://localhost:3000
